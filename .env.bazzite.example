# ============================================================
#  Kina · .env de ejemplo para servidor provisional Bazzite
#  Copia este archivo a  .env  EN EL SERVIDOR y ajusta valores.
#  NUNCA subas tu .env real a git. No pongas contraseñas aquí.
# ============================================================

APP_NAME=Kina
# staging = servidor provisional (no es producción final ni tu maquina dev)
APP_ENV=staging
# Se genera EN EL SERVIDOR con: php artisan key:generate
APP_KEY=
# En staging deja el debug APAGADO (no filtres stacktraces en la LAN)
APP_DEBUG=false

# URL con la que accedes al servidor. Ejemplos:
#   http://192.168.1.50        (IP LAN, sin dominio)
#   http://kina.local          (si configuras /etc/hosts o mDNS)
#   https://kina.tu-tailnet.ts.net  (si usas Tailscale con HTTPS)
APP_URL=http://192.168.1.50

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ---------- Base de datos ----------
# Usa MariaDB/MySQL con un usuario DEDICADO (nunca root).
# La contraseña real va SOLO en el .env del servidor, no aquí.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kina
DB_USERNAME=kina_user
DB_PASSWORD=cambia_esta_password

# ---------- Sesión / cookies ----------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# En LAN sin HTTPS debe ser false; si sirves por HTTPS (Tailscale/Cloudflare) ponlo en true.
SESSION_SECURE_COOKIE=false

# ---------- Colas ----------
# 'sync' procesa en el mismo request (suficiente para el MVP).
# Cambia a 'database' si activas el worker systemd (deploy/systemd/kina-queue.service).
QUEUE_CONNECTION=sync

BROADCAST_CONNECTION=log
# Guarda las fotos en storage/app/public (servidas vía storage:link)
FILESYSTEM_DISK=public

CACHE_STORE=database

# ---------- Correo ----------
# En staging basta con 'log' (los correos van a storage/logs, no se envían).
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@kina.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
